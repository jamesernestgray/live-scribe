{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Live Scribe",
  "version": "0.1.0",
  "identifier": "com.livescribe.app",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:8765"
  },
  "app": {
    "windows": [
      {
        "title": "Live Scribe",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "url": "http://localhost:8765"
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:8765 ws://localhost:8765; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "Live Scribe"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "deb", "appimage", "msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": null
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-dev",
          "libappindicator3-dev"
        ]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "windows": {
      "nsis": {
        "installMode": "both"
      }
    },
    "resources": [
      "../../live_scribe.py",
      "../../requirements.txt"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
